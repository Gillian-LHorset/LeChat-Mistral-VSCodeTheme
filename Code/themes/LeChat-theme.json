{
  "name": "LeChat Mistral Theme",
  "type": "dark",
  "colors": {
    "editorCursor.foreground": "#fa500f",
    "editorBracketHighlight.foreground1": "#fa500f",
    "editorBracketHighlight.foreground2": "#FF8205",
    "editorBracketHighlight.foreground3": "#FFF5BC",
    "editorBracketHighlight.unexpectedBracket.foreground": "#41A594",
    "titleBar.activeBackground": "#181818",
    "activityBar.background": "#181818",
    "editor.background": "#1f1f1f",
    "editorGroupHeader.tabsBackground": "#181818",
    "editorGroupHeader.noTabsBackground": "#181818",
    "tab.inactiveBackground": "#181818",
    "sideBar.background": "#181818",
    "panel.background": "#181818",
    "terminalCursor.foreground": "#fa500f",
    "terminal.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#fa500f",
    "statusBar.background": "#fa500f"
  },
  "tokenColors": [
    {
      "desc": "Couleur des valeurs (strings) JSON",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#FFF5BC"
      }
    },
    {
      "name": "Primary Orange (Keywords, Operators, Flow)",
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.operator",
        "keyword.control",
        "meta.brace.round"
      ],
      "settings": {
        "foreground": "#FA500F"
      }
    },
    {
      "name": "Off-White (Variables, Booleans, Params)",
      "scope": [
        "variable.other",
        "variable.parameter",
        "support.variable.property",
        "constant.language",
        "meta.object-literal.key",
        "variable.object.property",
        "constant.other.object.key"
      ],
      "settings": {
        "foreground": "#FFF5BC"
      }
    },
    {
      "name": "Secondary Orange (Functions, This)",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#FF8205"
      }
    },
    {
      "name": "Strings",
      "scope": ["string"],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#E17DD2"
      }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#828282"
      }
    },
    {
      "name": "White Elements",
      "scope": [
        "punctuation.terminator",
        "punctuation.separator",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "variable.other.readwrite.alias",
        "variable.other.property",
        "meta.definition.property"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    }
  ]
}
